config network
    option download_base_kbits    50000
    option download_interface     'ifb4wan'
    option download_min_percent   20
    option upload_base_kbits      10000
    option upload_interface       'wan'
    option upload_min_percent     20

config output
    option log_level              'error'
    option speed_hist_file        '/tmp/sqm-speedhist-rust.csv'
    option stats_file             '/tmp/sqm-autorate-rust.csv'
    option suppress_statistics    false

config observability
    option enabled                false
    option protocol               'udp'
    option host                   '192.168.1.100'
    option port                   8089
    option batch_size             25
    option batch_timeout_ms       100
    option export_ping_metrics    false
    option export_rate_metrics    true
    option export_baseline_metrics false
    option export_events          true

config advanced_settings
    option download_delay_ms      15
    option high_load_level        0.8
    option measurement_type       'icmp_timestamps'
    option min_change_interval    0.5
    option num_reflectors         5
    option peer_reselection_time  15
    option reflector_list_file    '/etc/sqm-autorate-rust/reflectors-icmp.csv'
    option speed_hist_size        100
    option tick_interval          0.5
    option upload_delay_ms        15
    option dry_run                false
